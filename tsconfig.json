{
  "compilerOptions": {
    "target": "ES2022",

    "module": "ESNext",
    "moduleResolution": "Bundler",

    "paths": {
      "@dagify/shared": [
        "./packages/shared/src"
      ],
      "@dagify/core": [
        "./packages/core/src"
      ],
      "@dagify/sdk": [
        "./packages/sdk/src"
      ]
    },

    "lib": ["ES2022"],

    "strict": true,

    "declaration": true,
    "declarationMap": true,

    "sourceMap": true,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,

    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true
  },

  "include": [
    "packages/**/*.ts",
    "apps/**/*.ts",
    "examples/**/*.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}